generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Carrera {
  id         Int         @id @default(autoincrement())
  nombre     String
  materias   Materia[]
  matriculas Matricula[]
}

model Estudiante {
  id         Int         @id @default(autoincrement())
  nombre     String
  matriculas Matricula[]
}

model Materia {
  id              Int             @id @default(autoincrement())
  nombre          String
  carreraId       Int
  carrera         Carrera         @relation(fields: [carreraId], references: [id])
  matriculas      Matricula[]
  asignacionesLab AsignacionLab[]
}

model Ciclo {
  id              Int             @id @default(autoincrement())
  nombre          String
  activo          Boolean         @default(true)
  matriculas      Matricula[]
  asignacionesLab AsignacionLab[]
}

model Matricula {
  id           Int     @id @default(autoincrement())
  activa       Boolean @default(true)
  estudianteId Int
  carreraId    Int
  cicloId      Int
  materiaId    Int

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  carrera    Carrera    @relation(fields: [carreraId], references: [id])
  ciclo      Ciclo      @relation(fields: [cicloId], references: [id])
  materia    Materia    @relation(fields: [materiaId], references: [id])
}

model Laboratorio {
  id           Int             @id @default(autoincrement())
  nombre       String
  asignaciones AsignacionLab[]
}

model AsignacionLab {
  id            Int @id @default(autoincrement())
  laboratorioId Int
  cicloId       Int
  materiaId     Int

  laboratorio Laboratorio @relation(fields: [laboratorioId], references: [id])
  ciclo       Ciclo       @relation(fields: [cicloId], references: [id])
  materia     Materia     @relation(fields: [materiaId], references: [id])
}
